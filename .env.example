# انسخ هذا الملف إلى .env وعدّل القيم
# copy .env.example .env

# مفتاح سري لتوقيع رموز JWT — استبدله بقيمة عشوائية طويلة
# يمكنك توليد واحد عبر: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-string

# مدة صلاحية رمز الدخول بالدقائق
ACCESS_TOKEN_EXPIRE_MINUTES=60

# عنوان قاعدة البيانات (SQLite افتراضياً)
DATABASE_URL=sqlite:///./app.db
